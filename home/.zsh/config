# Load zsh massive renamer
# autoload -U zmv

# Turn off auto correct
unsetopt correct_all

# Don't hang up background jobs
setopt no_hup

# History
export HISTFILE=~/.zhistory
export HISTSIZE="100000"
export SAVEHIST="100000"

setopt append_history
setopt hist_expire_dups_first
setopt extended_history

# Don't show duplicate history entires
setopt hist_find_no_dups

# Remove unnecessary blanks from history
setopt hist_reduce_blanks

# Share history between instances
setopt share_history

# Editor
export EDITOR="code"
export GIT_EDITOR="$EDITOR --wait"
export VISUAL=$EDITOR

# Set to number of cpus
export MAKEFLAGS="-j4"
export BUNDLE_JOBS="4"

export GOPATH=$HOME/go

# Detect Homebrew prefix based on architecture
if [[ "$(uname -m)" == "arm64" ]]; then
  export HOMEBREW_PREFIX=/opt/homebrew
else
  export HOMEBREW_PREFIX=/usr/local
fi
eval "$($HOMEBREW_PREFIX/bin/brew shellenv)"

# Tell compilers where to find openssl@3
export LDFLAGS="-L$HOMEBREW_PREFIX/opt/openssl@3/lib"
export CPPFLAGS="-I$HOMEBREW_PREFIX/opt/openssl@3/include"

# Tell pkg-config where to find openssl@3
export PKG_CONFIG_PATH="$HOMEBREW_PREFIX/opt/openssl@3/lib/pkgconfig"

PATH="/Applications/Visual Studio Code.app/Contents/Resources/app/bin:$PATH"
PATH="$HOMEBREW_PREFIX/opt/gnu-sed/libexec/gnubin:$HOMEBREW_PREFIX/opt/coreutils/libexec/gnubin:$PATH"
PATH="$HOMEBREW_PREFIX/opt/openssl/bin:$PATH"
PATH="$GOPATH/bin:$PATH"
PATH="$HOME/.local/bin:$PATH"
PATH="$HOME/.cargo/bin:$PATH"
export PATH="$HOME/bin:$PATH"

# Add relative bins with highest precedent
PATH="node_modules/.bin:$PATH"
PATH=".bundle/bin:$PATH"
export PATH="bin:$PATH"

# Setup zoxide to replace cd
eval "$(zoxide init zsh)"

# Load plugins
source $HOMEBREW_PREFIX/opt/zsh-fast-syntax-highlighting/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh
source $HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh

# asdf package manager
. $HOMEBREW_PREFIX/opt/asdf/libexec/asdf.sh

# Source rust/cargo env
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# Load env variables from .envrc - to enable: `direnv allow .`
eval "$(direnv hook zsh)"
